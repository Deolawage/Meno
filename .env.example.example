# Copy to .env and fill in your values. DO NOT commit .env to GitHub.

MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster.mongodb.net/meno
JWT_SECRET=pick_any_long_random_string_here
PORT=3000

# AI Study Assistant - Get free key at https://console.anthropic.com
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY

# Push Notifications - generate with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_EMAIL=mailto:you@example.com
